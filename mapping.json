{
    "mapping_metadata": {
        "source_dataset": "eICU",
        "target_model": "Backbone"
    },
    "nodes": {
        "Patient": {
            "source_reference": "uniquepid",
                "age":"age",
                "gender":"gender",
                "ethnicity":"ethnicity"
        },
        "Encounter": {
            "source_reference": "patienthealthsystemstayid",
            "concept_id": "None",
            "concept_label": "None",
            "type": "encounter",
            "start_time": "hospitaladmittime24 + hospitaladmitoffset",
            "end_time": "hospitaldischargetime24 + hospitaldischargeoffset",
            "payload": []
        },
        "Encounter_Segment": {
            "source_reference": "patientunitstayid",
            "type": "encounter_segment",
            "concept_id":"None",
            "concept_label": "None",
            "start_time": "unitadmittime24",
            "end_time": "unitdischargetime24 + unitdiscargeoffset",
            "payload": [    
                "unit_visit_number",
                "unitstaytype",
                "unittype"
            ]
        },
        "HospitalAdmission": {
            "type": "event",
            "source_reference": "patienthealthsystemstayid",
            "concept_label": "None",
            "concept_id" :"None",
            "start_time": "hospitaladmittime24 + hospitaladmitoffset",
            "payload": [
                "hospitaladmitsource",
                "admissionheight",
                "admissionweight"
            ]
        },
        "HospitalDischarge": {
            "type": "event",
            "source_reference": "patienthealthsystemstayid",
            "concept_label": "None",
            "concept_id" :"None",
            "timestamp": "hospitaldischargetime24 + hospitaldischargeoffset",
            "payload": [
                "hospitaldischargestatus",
                "hospitaldischargelocation",
                "hospitaldischargeyear",
                "dischargeweight"
            ]
        },
        "ICU_Admit": {
            "type": "event",
            "source_reference": "patientunitstayid",
            "concept_label": "None",
            "concept_id" :"None",
            "timestamp": "unitadmittime24",
            "payload": [
                "unitadmitsource",
                "unittype",
                "unitstaytype"
            ]
        },
        "ICU_Discharge": {
           "type": "event",
            "source_reference": "patientunitstayid",
            "concept_label": "None",
            "concept_id" :"None",
            "timestamp": "unitadmittime24",
            "payload": [
                "unitadmitsource",
                "unittype",
                "unitstaytype"
            ]
        },
        "Location_Hospital": {
            "source_reference": "HOSP_{hospitalid}"
        },
        "Location_Ward": {
            "source_reference": "HOSP_{hospitalid}_Ward_{wardid}"
        },
        
        "Location_admit_discharge_Hospital_and_": { 
            "source_reference": "hospitaladmitsource or hospitaldischargelocation or unitdischargelocation or unitadmitsource"
        }
    },
    "relationships": [
        {
            "from": "Patient",
            "to": "Encounter",
            "type": "HAS_EVENT",
            "join_key": {
                "from_field": "uniquepid",
                "to_field": "patienthealthsystemstayid"
            }
        },
        {
            "from": "Patient",
            "to": "Encounter_Segment",
            "type": "HAS_ENCOUNTER_SEGMENT",
            "join_key": {
                "from_field": "uniquepid",
                "to_field": "patientunitstayid"
            }
        },
        {
            "from": "Encounter",
            "to": "Encounter_Segment",
            "type": "HAS_SEGMENT",
            "join_key": {
                "from_field": "patienthealthsystemstayid",
                "to_field": "patientunitstayid"
            }
        },
        {
            "from": "Encounter",
            "to": "Location_Hospital",
            "type": "HAS_LOCATION",
            "join_key": {
                "from_field": "patienthealthsystemstayid",
                "to_field": "HOSP_{hospitalid}"
            }
        },
        {
            "from": "Encounter_Segment",
            "to": "Location_Ward",
            "type": "HAS_LOCATION",
            "join_key": {
                "from_field": "patientunitstayid",
                "to_field": "HOSP_{hospitalid}_Ward_{wardid}"
            }
        },
        {
            "from": "Encounter",
            "to": "HospitalAdmission",
            "type": "HAS_Hospital_ADMISSION",
            "join_key": "patienthealthsystemstayid"
        },
        {
            "from": "Encounter",
            "to": "HospitalDischarge",
            "type": "HAS_Hospital_DISMISSION",
            "join_key": "patienthealthsystemstayid"
        },
        {
            "from": "Encounter_Segment",
            "to": "ICU_Admit",
            "type": "HAS_ICU_ADMISSION",
            "join_key": "patientunitstayid"
        },
        {
            "from": "Encounter_Segment",
            "to": "ICU_Discharge",
            "type": "HAS_ICU_DISMISSION",
            "join_key": "patientunitstayid"
        },
        {
            "from": "ICU_Admit",
            "to": "Location_Ward",
            "type": "HAS_LOCATION",
            "join_key": {
                "from_field": "patientunitstayid",
                "to_field": "HOSP_{hospitalid}_Ward_{wardid}"
            }
        },
        {
            "from": "ICU_Discharge",
            "to": "Location_Ward",
            "type": "HAS_LOCATION",
            "join_key": {
                "from_field": "patientunitstayid",
                "to_field": "HOSP_{hospitalid}_Ward_{wardid}"
            }
        },
        {
            "from": "HospitalAdmission",
            "to": "Location_admit_discharge",
            "type": "HAS_LOCATION",
            "join_key": "hospitaladmitsource"
        },
        {
            "from": "HospitalDischarge",
            "to": "Location_admit_discharge",
            "type": "HAS_LOCATION",
            "join_key": "hospitaldischargelocation"
        }
    ]
}