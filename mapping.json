{
    "mapping_metadata": {
        "source_dataset": "eICU",
        "target_model": "Backbone",
        "version": "1.0.0",
        "csv_file": "patient.csv"
    },
    "nodes": {
        "Patient": {
            "source_reference": "uniquepid",
                "age": "age"
        },
        "Local_Concept": {
            "source_reference": "__derived_from_column_value__",
            "identity_key": ["source_value", "type"],
            "properties": {
                "source_value": "__column_value__",
                "type": "__column_name__"
            },
            "_comment": "Uniqueness is enforced on the composite key (source_value, type). Each distinct (value, category) pair is one node."
        },
        "Encounter": {
            "source_reference": "patienthealthsystemstayid",
            "type": "Encounter",
            "concept_label": null,
            "concept_id": null,
            "start_time": "hospitaladmittime24 + hospitaladmitoffset",
            "end_time": "hospitaldischargetime24 + hospitaldischargeoffset",
            "payload": [
                "admissionheight",
                "hospitaldischargeyear",
                "admissionweight",
                "dischargeweight"
            ]
        },
        "Encounter_Segment": {
            "source_reference": "patientunitstayid",
            "type": "Encounter Segment",
            "concept_label": null,
            "concept_id": null,
            "start_time": "unitadmittime24",
            "end_time": "unitdischargetime24 + unitdischargeoffset",
            "payload": ["unitvisitnumber"]
        },
        "Location": {
            "source_reference": "__derived_from_column_value__"
        }
    },
    "relationships": [
        {
            "from": "Patient",
            "to": "Local_Concept",
            "type": "HAS_LOCAL_CONCEPT",
            "properties": { "type": "__column_name__" }
        },
        {
            "from": "Patient",
            "to": "Encounter_Segment",
            "type": "HAS_ENCOUNTER_SEGMENT",
            "join_key": {
                "from_field": "uniquepid",
                "to_field": "patientunitstayid"
            }
        },
        {
            "from": "Encounter",
            "to": "Local_Concept",
            "type": "HAS_LOCAL_CONCEPT",
            "properties": { "type": "__column_name__" }
        },
        {
            "from": "Encounter_Segment",
            "to": "Local_Concept",
            "type": "HAS_LOCAL_CONCEPT",
            "properties": { "type": "__column_name__" }
        },
        {
            "from": "Patient",
            "to": "Encounter",
            "type": "HAS_EVENT",
            "join_key": {
                "from_field": "uniquepid",
                "to_field": "patienthealthsystemstayid"
            },
            "properties": {
                "source": "unitadmitsource",
                "dismission": "unitdischargelocation"
            }
        },
        {
            "from": "Encounter",
            "to": "Encounter_Segment",
            "type": "HAS_ENCOUNTER_SEGMENT",
            "join_key": {
                "from_field": "patienthealthsystemstayid",
                "to_field": "patientunitstayid"
            },
            "properties": {
                "source": "unitadmitsource",
                "dismission": "unitdischargelocation"
            }
        },
        {
            "from": "Encounter",
            "to": "Location",
            "type": "HAS_LOCATION"
        },
        {
            "from": "Encounter_Segment",
            "to": "Location",
            "type": "HAS_LOCATION"
        }
    ]
}