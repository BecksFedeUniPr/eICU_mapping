{
    "mapping_metadata": {
        "source_dataset": "eICU",
        "target_model": "Backbone"
    },
    "nodes": {
        "Patient": {
            "source_reference": "uniquepid",
            "age": "age"
        },
        "Local_Concept": {
            "source_value": "type"
        },
        "Encounter": {
            "source_reference": "patienthealthsystemstayid",
            "start_time": "hospitaladmittime24 + hospitaladmitoffset",
            "end_time": "hospitaldischargetime24 + hospitaldischargeoffset",
            "concept_label": "None",
            "concept_id": "None",
            "payload": [
                "admissionheight",
                "hospitaldischargeyear",
                "admissionweight",
                "dischargeweight"
            ],
            "type": "Encounter"
        },
        "Encounter_Segment": {
            "source_reference": "patientunitstayid",
            "start_time": "unit_admit_time",
            "end_time": "unitdischargetime24 + unitdischargeoffset",
            "concept_label": "None",
            "concept_id": "None",
            "type": "Encounter Segment"
        },
        "Location": {
            "source_reference": null
        }
    },
    "relationships": [
        {
            "from": "Patient",
            "to": "Local_Concept",
            "type": "HAS_LOCAL_CONCEPT",
            "properties": ["type"]
        },
        {
            "from": "Patient",
            "to": "Encounter_Segment",
            "type": "HAS_ENCOUNTER_SEGMENT"
        },
        {
            "from": "Encounter",
            "to": "Local_Concept",
            "type": "HAS_LOCAL_CONCEPT",
            "properties": ["type"]
        },
        {
            "from": "Encounter_Segment",
            "to": "Local_Concept",
            "type": "HAS_LOCAL_CONCEPT",
            "properties": ["type"]
        },
        {
            "from": "Patient",
            "to": "Encounter",
            "type": "HAS_EVENT",
            "properties": ["source", "dismission"],
            "join_key": {
                "from_field": "uniquepid",
                "to_field": "patienthealthsystemstayid"
            }
        },
        {
            "from": "Encounter",
            "to": "Encounter_Segment",
            "type": "HAS_ENCOUNTER_SEGMENT",
            "properties": ["source", "dismission"],
            "join_key": {
                "from_field": "patienthealthsystemstayid",
                "to_field": "patientunitstayid"
            }
        },
        {
            "from": "Encounter",
            "to": "Location",
            "type": "HAS_LOCATION"
        },
        {
            "from": "Encounter_Segment",
            "to": "Location",
            "type": "HAS_LOCATION"
        }
    ]
}